/*---------------------------------------------------*/
/* PROGRAM  : DEPLOYDMO                              */
/* PURPOSE  : MONTH END SALES PROCESSING JOB        */
/* AUTHOR   : SHARMIT                               */
/* DATE     : 2026                                  */
/*---------------------------------------------------*/
PGM

/* DECLARE VARIABLES */
DCL VAR(&RUNDATE)  TYPE(*CHAR) LEN(8)
DCL VAR(&RUNLIB)   TYPE(*CHAR) LEN(10)
DCL VAR(&STATUS)   TYPE(*CHAR) LEN(1)
DCL VAR(&ERRMSG)   TYPE(*CHAR) LEN(50)
DCL VAR(&JOBNAME)  TYPE(*CHAR) LEN(10)
DCL VAR(&RTNCODE)  TYPE(*DEC)  LEN(5 0)

/* INITIALIZE */
CHGVAR VAR(&RUNLIB)  VALUE('SHARMITTS1')
CHGVAR VAR(&STATUS)  VALUE('N')
CHGVAR VAR(&RTNCODE) VALUE(0)

/* GET CURRENT DATE */
RTVSYSVAL SYSVAL(QDATE) RTNVAR(&RUNDATE)

/* SEND START MESSAGE */
SNDPGMMSG MSG('DEPLOYDMO : MONTH END PROCESSING STARTED ' +
              *CAT &RUNDATE) +
          MSGTYPE(*INFO)

/* CHECK DATA AREA EXISTS */
CHKOBJ OBJ(SHARMITTS1/MONTHCTL) OBJTYPE(*DTAARA)
MONMSG MSGID(CPF9801) EXEC(DO)
  CHGVAR VAR(&ERRMSG) VALUE('DATA AREA MONTHCTL NOT FOUND')
  SNDPGMMSG MSG(&ERRMSG) MSGTYPE(*ESCAPE)
  GOTO CMDLBL(ENDJOB)
ENDDO

/* RETRIEVE DATA AREA VALUE */
RTVDTAARA DTAARA(SHARMITTS1/MONTHCTL) RTNVAR(&STATUS)

/* CHECK IF ALREADY RUN */
IF COND(&STATUS = 'Y') THEN(DO)
  SNDPGMMSG MSG('DEPLOYDMO : ALREADY RUN FOR THIS MONTH') +
            MSGTYPE(*INFO)
  GOTO CMDLBL(ENDJOB)
ENDDO

/* STEP 1 - RUN SALES VALIDATION */
SNDPGMMSG MSG('DEPLOYDMO : CALLING SALESVLD') +
          MSGTYPE(*INFO)

CALL PGM(SHARMITTS1/SALESVLD) PARM(&RUNDATE &RTNCODE)
MONMSG MSGID(CPF0000) EXEC(DO)
  CHGVAR VAR(&ERRMSG) VALUE('SALESVLD FAILED')
  SNDPGMMSG MSG(&ERRMSG) MSGTYPE(*ESCAPE)
  GOTO CMDLBL(ENDJOB)
ENDDO

/* CHECK RETURN CODE FROM SALESVLD */
IF COND(&RTNCODE *NE 0) THEN(DO)
  SNDPGMMSG MSG('DEPLOYDMO : SALESVLD ERROR CODE ' *CAT +
               &RTNCODE) MSGTYPE(*ESCAPE)
  GOTO CMDLBL(ENDJOB)
ENDDO

/* STEP 2 - SUBMIT SALES REPORT TO BATCH */
SNDPGMMSG MSG('DEPLOYDMO : SUBMITTING SALESRPT TO BATCH') +
          MSGTYPE(*INFO)

SBMJOB CMD(CALL PGM(SHARMITTS1/SALESRPT) +
           PARM(&RUNDATE)) +
       JOB(SALESRPT) +
       JOBD(SHARMITTS1/SALESJOBD) +
       JOBQ(SHARMITTS1/SALESJOBQ) +
       OUTQ(SHARMITTS1/SALESOUTQ)

MONMSG MSGID(CPF0000) EXEC(DO)
  CHGVAR VAR(&ERRMSG) VALUE('SBMJOB SALESRPT FAILED')
  SNDPGMMSG MSG(&ERRMSG) MSGTYPE(*ESCAPE)
  GOTO CMDLBL(ENDJOB)
ENDDO

/* STEP 3 - CALL MONTH END UPDATE */
SNDPGMMSG MSG('DEPLOYDMO : CALLING MTHENDUPD') +
          MSGTYPE(*INFO)

CALL PGM(SHARMITTS1/MTHENDUPD) PARM(&RUNDATE &STATUS)
MONMSG MSGID(CPF0000) EXEC(DO)
  CHGVAR VAR(&ERRMSG) VALUE('MTHENDUPD FAILED')
  SNDPGMMSG MSG(&ERRMSG) MSGTYPE(*ESCAPE)
  GOTO CMDLBL(ENDJOB)
ENDDO

/* UPDATE DATA AREA - MARK AS RUN */
CHGDTAARA DTAARA(SHARMITTS1/MONTHCTL) VALUE('Y')

/* SEND SUCCESS MESSAGE */
SNDPGMMSG MSG('DEPLOYDMO : MONTH END COMPLETED SUCCESSFULLY') +
          MSGTYPE(*INFO)

ENDJOB:
SNDPGMMSG MSG('DEPLOYDMO : JOB ENDED STATUS=' *CAT &STATUS) +
          MSGTYPE(*INFO)

ENDPGM

