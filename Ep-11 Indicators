**FREE

// ------------------------------------------------
// PROGRAM  : INDRPT
// PURPOSE  : INDICATOR ANALYSIS DEMO FOR BOB
// ------------------------------------------------

DCL-S WCUSNO   CHAR(5);
DCL-S WCUSNAM  CHAR(20);
DCL-S WCUSBAL  PACKED(9:2);
DCL-S WDISAMT  PACKED(9:2);
DCL-S WMSG     CHAR(52);
DCL-S WIDX     INT(10);

DCL-DS CUSDS QUALIFIED DIM(3);
  CUSNO   CHAR(5);
  CUSNAM  CHAR(20);
  CUSBAL  PACKED(9:2);
  CUSTYP  CHAR(1);
END-DS;

CUSDS(1).CUSNO  = '00001';
CUSDS(1).CUSNAM = 'JOHN SMITH';
CUSDS(1).CUSBAL = 1000.00;
CUSDS(1).CUSTYP = 'G';

CUSDS(2).CUSNO  = '00002';
CUSDS(2).CUSNAM = 'JANE DOE';
CUSDS(2).CUSBAL = 2000.00;
CUSDS(2).CUSTYP = 'S';

CUSDS(3).CUSNO  = '00003';
CUSDS(3).CUSNAM = 'BOB MARTIN';
CUSDS(3).CUSBAL = 500.00;
CUSDS(3).CUSTYP = 'R';

// INITIALIZE
*IN50 = *OFF;
*IN51 = *OFF;
*IN60 = *OFF;
*IN90 = *OFF;
*IN91 = *OFF;
*IN95 = *OFF;

DSPLY '*** PROGRAM START ***';

FOR WIDX = 1 TO 3;

  WCUSNO  = CUSDS(WIDX).CUSNO;
  WCUSNAM = CUSDS(WIDX).CUSNAM;
  WCUSBAL = CUSDS(WIDX).CUSBAL;

  // LAST RECORD CHECK
  IF WIDX = 3;
    *IN90 = *ON;
  ENDIF;

  // CUSTOMER TYPE
  *IN50 = *OFF;
  *IN51 = *OFF;
  *IN60 = *OFF;

  IF CUSDS(WIDX).CUSTYP = 'G';
    *IN50 = *ON;
  ELSEIF CUSDS(WIDX).CUSTYP = 'S';
    *IN51 = *ON;
  ELSE;
    *IN60 = *ON;
  ENDIF;

  // DISCOUNT
  *IN91 = *OFF;

  IF *IN50 = *ON;
    WDISAMT = WCUSBAL * 0.20;
    *IN91   = *ON;
  ELSEIF *IN51 = *ON;
    WDISAMT = WCUSBAL * 0.15;
    *IN91   = *ON;
  ELSE;
    WDISAMT = 0;
  ENDIF;

  // HIGH BALANCE CHECK - NOTE: *IN95 SET BUT NEVER TESTED
  IF WCUSBAL > 1500;
    *IN95 = *ON;
  ENDIF;

  // DISPLAY
  IF *IN91 = *ON;
    WMSG = %TRIMR(WCUSNAM) + ' DISC=' + %CHAR(WDISAMT);
    DSPLY WMSG;
  ELSE;
    WMSG = %TRIMR(WCUSNAM) + ' NO DISCOUNT';
    DSPLY WMSG;
  ENDIF;

  IF *IN90 = *ON;
    DSPLY '*** LAST RECORD ***';
  ENDIF;

ENDFOR;

DSPLY '*** PROGRAM END ***';

*INLR = *ON;


