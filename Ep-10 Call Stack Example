// ================================================
// PROGRAM  : CALCDIS
// LEVEL    : 2
// PURPOSE  : CALCULATE DISCOUNT
// CALLED BY: MAINPGM
// CALLS    : CALCTAX
// ================================================

// PROCEDURE INTERFACE - PARAMETERS FROM MAINPGM
DCL-PI CALCDIS;
  PORDAMT   PACKED(9:2) VALUE;
  PDISAMT   PACKED(9:2);
  PTAXAMT   PACKED(9:2);
  PNETAMT   PACKED(9:2);
END-PI;

// PROTOTYPE FOR CALCTAX
DCL-PR CALCTAX;
  PORDAMT   PACKED(9:2) VALUE;
  PDISAMT   PACKED(9:2) VALUE;
  PTAXAMT   PACKED(9:2);
END-PR;

// LOCAL FIELDS
DCL-S WMSG  CHAR(52);

DSPLY 'CALCDIS : RECEIVED ORDAMT=' + %CHAR(PORDAMT);

// CALCULATE 10% DISCOUNT
PDISAMT = PORDAMT * 0.10;
WMSG = 'CALCDIS : DISAMT = ' + %CHAR(PDISAMT);
DSPLY WMSG;

DSPLY 'CALCDIS : CALLING CALCTAX --->';

// ACTUAL PROGRAM CALL TO CALCTAX
CALLP CALCTAX(PORDAMT :
              PDISAMT :
              PTAXAMT);

WMSG = 'CALCDIS : TAXAMT = ' + %CHAR(PTAXAMT);
DSPLY WMSG;

// CALCULATE NET AMOUNT
PNETAMT = PORDAMT - PDISAMT + PTAXAMT;
WMSG = 'CALCDIS : NETAMT = ' + %CHAR(PNETAMT);
DSPLY WMSG;

DSPLY 'CALCDIS : RETURNING TO MAINPGM <---';

*INLR = *ON;

