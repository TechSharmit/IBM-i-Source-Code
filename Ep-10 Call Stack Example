// ================================================
// PROGRAM  : MAINPGM
// LEVEL    : 1 - TOP OF CALL STACK
// PURPOSE  : MAIN DRIVER
// CALLS    : CALCDIS
// ================================================

DCL-S WORDAMT  PACKED(9:2);
DCL-S WDISAMT  PACKED(9:2);
DCL-S WTAXAMT  PACKED(9:2);
DCL-S WNETAMT  PACKED(9:2);
DCL-S WCUSNO   CHAR(5);
DCL-S WMSG     CHAR(52);

// PROTOTYPE FOR CALCDIS
DCL-PR CALCDIS;
  PORDAMT   PACKED(9:2) VALUE;
  PDISAMT   PACKED(9:2);
  PTAXAMT   PACKED(9:2);
  PNETAMT   PACKED(9:2);
END-PR;

// SET INPUT VALUES
WCUSNO  = '00001';
WORDAMT = 1000.00;
WDISAMT = 0;
WTAXAMT = 0;
WNETAMT = 0;

DSPLY '*** MAINPGM : START ***';
WMSG = 'MAINPGM : CUSNO  = ' + WCUSNO;
DSPLY WMSG;
WMSG = 'MAINPGM : ORDAMT = ' + %CHAR(WORDAMT);
DSPLY WMSG;
DSPLY 'MAINPGM : CALLING CALCDIS --->';

// ACTUAL PROGRAM CALL TO CALCDIS
CALLP CALCDIS(WORDAMT :
              WDISAMT :
              WTAXAMT :
              WNETAMT);

WMSG = 'MAINPGM : DISAMT = ' + %CHAR(WDISAMT);
DSPLY WMSG;
WMSG = 'MAINPGM : TAXAMT = ' + %CHAR(WTAXAMT);
DSPLY WMSG;
WMSG = 'MAINPGM : NETAMT = ' + %CHAR(WNETAMT);
DSPLY WMSG;
DSPLY '*** MAINPGM : END ***';

*INLR = *ON;

